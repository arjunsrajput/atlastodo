<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('nav_bar') %>
    <div class="container">
        <h1>Task List Page</h1>
        <!-- <a href="/delete"><button class="btn2">Delete</button></a> -->
        <ul class="task-list">
            <% for(let i=0;i<data.length;i++){ %>
                <li class="task-item">
                    <div class="task-title">
                        <%= data[i].title%>
                    </div>
                    <div class="task-description">
                        <%= data[i].description%>
                    </div>
                    <a href="/delete/<%= data[i]._id%>"><button class="btn2">Delete</button></a>
                    <a href="/update/<%= data[i]._id%>"><button class="btn3">Update</button></a>
                </li>
            <%}%>
        </ul>
    </div>

</body>
</html>